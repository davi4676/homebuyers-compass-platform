# Copy to .env.local and fill with your Stripe Dashboard values (test mode shown).

# Stripe — required for checkout (server)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe — required for embedded / client flows
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe Price IDs — monthly subscriptions
STRIPE_PRICE_MOMENTUM_MONTHLY=price_...
STRIPE_PRICE_NAVIGATOR_MONTHLY=price_...
# Concierge+ tier (Navigator+ in code); legacy aliases still supported in lib/stripe.ts
STRIPE_PRICE_CONCIERGE_MONTHLY=price_...
STRIPE_PRICE_NAVIGATOR_PLUS_MONTHLY=price_...

# Stripe Price IDs — one-time (optional; legacy checkout)
STRIPE_PRICE_MOMENTUM_ONETIME=price_...
STRIPE_PRICE_NAVIGATOR_ONETIME=price_...
STRIPE_PRICE_CONCIERGE_ONETIME=price_...
STRIPE_PRICE_NAVIGATOR_PLUS_ONETIME=price_...

# Stripe Price IDs — annual subscriptions (20% off vs 12× monthly)
STRIPE_PRICE_MOMENTUM_ANNUAL=price_...
STRIPE_PRICE_NAVIGATOR_ANNUAL=price_...
STRIPE_PRICE_CONCIERGE_ANNUAL=price_...
STRIPE_PRICE_NAVIGATOR_PLUS_ANNUAL=price_...

# Legacy env names (optional fallbacks — see lib/stripe.ts)
# STRIPE_PRICE_MOMENTUM_YEARLY=price_...
# STRIPE_PRICE_ID_MONTHLY=price_...

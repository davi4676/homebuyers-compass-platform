# Stripe – required for checkout and webhooks (without STRIPE_SECRET_KEY, /api/stripe/checkout returns 503)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# For local dev: run `stripe listen --forward-to localhost:3002/api/stripe/webhook` and use the printed whsec_ value
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — see prototype/STRIPE_SETUP.md for amounts (USD, from lib/stripe.ts TIER_AMOUNTS).
# Minimum shippable: 6 recurring prices (Momentum, Navigator, Navigator+ × monthly + yearly).
# Add one-time prices if you use /payment?cycle=one-time (9 prices total).
STRIPE_PRICE_MOMENTUM_MONTHLY=price_...
STRIPE_PRICE_MOMENTUM_YEARLY=price_...
STRIPE_PRICE_MOMENTUM_ONETIME=price_...
STRIPE_PRICE_NAVIGATOR_MONTHLY=price_...
STRIPE_PRICE_NAVIGATOR_YEARLY=price_...
STRIPE_PRICE_NAVIGATOR_ONETIME=price_...
STRIPE_PRICE_NAVIGATOR_PLUS_MONTHLY=price_...
STRIPE_PRICE_NAVIGATOR_PLUS_YEARLY=price_...
STRIPE_PRICE_NAVIGATOR_PLUS_ONETIME=price_...

# Optional: DPA Match Report ($19 one-time). If unset, checkout uses inline price_data.
STRIPE_PRICE_DPA_REPORT=price_...

# Optional: Completion Certificate ($29 one-time). If unset, checkout uses inline price_data.
STRIPE_PRICE_COMPLETION_CERTIFICATE=price_...

# Legacy aliases (optional — map to the same Stripe prices as above if you prefer short names)
# STRIPE_PRICE_ID_MONTHLY=price_...
# STRIPE_PRICE_ID_YEARLY=price_...
# STRIPE_PRICE_PREMIUM_MONTHLY=price_...
# STRIPE_PRICE_PREMIUM_YEARLY=price_...
# STRIPE_PRICE_PREMIUM_ONETIME=price_...
# STRIPE_PRICE_PRO_MONTHLY=price_...
# STRIPE_PRICE_PRO_YEARLY=price_...
# STRIPE_PRICE_PRO_ONETIME=price_...
# STRIPE_PRICE_PROPLUS_MONTHLY=price_...
# STRIPE_PRICE_PROPLUS_YEARLY=price_...
# STRIPE_PRICE_PROPLUS_ONETIME=price_...

# PostHog — optional product analytics (same as .env.local).
# Get your key: https://app.posthog.com/project/settings → Project API Key
# Leave empty to disable PostHog (no events sent).
# NEXT_PUBLIC_POSTHOG_KEY=

# Optional: Blink SDK
# NEXT_PUBLIC_BLINK_API_KEY=

# Reminder orchestration
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=replace_with_random_64_hex_chars

# Tier / journey review (no login required to browse app routes; shows floating tier switcher).
# Omit or set to false on locked-down production. Development mode enables this behavior without the var.
NEXT_PUBLIC_TIER_REVIEW_PUBLIC=true

# App URLs
# Local dev default
NEXT_PUBLIC_APP_URL=http://localhost:3002
APP_URL=http://localhost:3002

# Email provider (Resend)
RESEND_API_KEY=re_...
# Must be a verified sender/domain in Resend
RESEND_FROM=NestQuest <no-reply@yourdomain.com>

# Web push (VAPID)
# Generate with:
# node -e "const w=require('web-push'); console.log(w.generateVAPIDKeys())"
VAPID_PUBLIC_KEY=replace_with_vapid_public_key
VAPID_PRIVATE_KEY=replace_with_vapid_private_key
VAPID_SUBJECT=mailto:support@yourdomain.com

# Optional admin allowlist (comma-separated emails)
# Leave unset to disable allowlist enforcement
# ADMIN_EMAILS=admin1@yourdomain.com,admin2@yourdomain.com
